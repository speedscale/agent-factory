{
  "app": {
    "apiVersion": "agents.speedscale.io/v1alpha1",
    "kind": "AgentApp",
    "metadata": {
      "name": "node-demo"
    },
    "spec": {
      "repo": {
        "provider": "github",
        "url": "https://example.local/node-demo",
        "defaultBranch": "main",
        "workdir": "."
      },
      "quality": {
        "baseline": {
          "strategy": "single",
          "targets": [
            {
              "name": "app",
              "workdir": ".",
              "baselineRef": "baseline/local/node-demo/app"
            }
          ]
        },
        "reporting": {
          "formats": [
            "json",
            "markdown"
          ],
          "failOnRegression": true,
          "thresholds": {
            "maxBuildStderrLineDelta": 20,
            "maxValidationStderrLineDelta": 20
          }
        }
      },
      "build": {
        "install": "npm install",
        "test": "npm install && node --check index.js",
        "start": "npm start"
      },
      "validate": {
        "proxymock": {
          "dataset": "node-demo",
          "mode": "replay-with-mocks",
          "command": "proxymock replay --in ./proxymock/results/replayed-2026-04-09_01-03-25.75496Z --test-against localhost:3000 --fail-if requests.response-pct!=100",
          "service": {
            "command": "npm start",
            "host": "localhost",
            "port": 3000,
            "startupTimeoutSeconds": 30
          },
          "timeoutSeconds": 180,
          "maxNoOutputSeconds": 30,
          "retries": 0
        }
      }
    }
  },
  "issue": {
    "id": "manual-node-demo-run",
    "title": "Manual Node demo quality run",
    "body": "Run replay quality gate against Node demo app.",
    "url": "https://example.local/manual/node-demo"
  },
  "request": {
    "source": "developer",
    "mode": "baseline"
  }
}
