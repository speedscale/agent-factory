{
  "app": {
    "apiVersion": "agents.speedscale.io/v1alpha1",
    "kind": "AgentApp",
    "metadata": {
      "name": "replace-with-app-name"
    },
    "spec": {
      "repo": {
        "provider": "github",
        "url": "https://github.com/<owner>/<repo>",
        "defaultBranch": "main",
        "workdir": "."
      },
      "issue": {
        "labels": {
          "include": [
            "agent-ready",
            "bug",
            "validation-required"
          ]
        }
      },
      "build": {
        "install": "<install command>",
        "test": "<test command>",
        "start": "<start command>"
      },
      "validate": {
        "proxymock": {
          "dataset": "<dataset>",
          "mode": "replay-with-mocks",
          "command": "<validation command>",
          "service": {
            "command": "<service start command>",
            "host": "localhost",
            "port": 8081,
            "startupTimeoutSeconds": 90
          },
          "dependencies": {
            "setupCommand": "<optional setup command>",
            "teardownCommand": "<optional teardown command>"
          }
        }
      },
      "policy": {
        "autoBranch": true,
        "autoMr": false,
        "autoMerge": false
      }
    }
  },
  "issue": {
    "id": "<issue-id>",
    "title": "<issue-title>",
    "body": "<problem statement + expected behavior + acceptance checks>",
    "url": "https://github.com/<owner>/<repo>/issues/<number>"
  },
  "evidence": {
    "discovery": {
      "source": "both",
      "notes": "<what logs or captures showed before patching>"
    },
    "capture": {
      "dataset": "<proxymock dataset>",
      "downloadCommand": "<command used to pull capture>",
      "requestResponseSummary": "<key request path and observed/expected status details>"
    },
    "reproduction": {
      "steps": [
        "<step 1>",
        "<step 2>"
      ],
      "expectedBehavior": "<expected behavior>",
      "observedBehavior": "<observed behavior>"
    },
    "suspectedBug": "<likely root cause before code fix>",
    "fixSummary": "<summary of proposed fix intent>"
  }
}
