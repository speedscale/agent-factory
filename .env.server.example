AGENT_FACTORY_IMAGE=ghcr.io/speedscale/agent-factory:v0.1.0

# queue backend
RUN_QUEUE_BACKEND=redis
REDIS_URL=redis://redis:6379
REDIS_QUEUE_KEY=agent-factory:runs:queued
RUN_QUEUE_BATCH_SIZE=25

# auth (leave blank to disable)
INTAKE_API_TOKEN=change-me

# worker runtime
# default demo source: /app/.work/demo-fixture
# real repo example (bind mount repo into container first): /repos/microsvc
WORKER_SOURCE=/app/.work/demo-fixture
WORKER_METRICS_PORT=9090
