{
  "name": "@speedscale/agent-factory",
  "version": "0.1.89",
  "private": true,
  "description": "Speedscale Agent Factory — traffic-context-grounded AI agents.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json && npm run check:no-anthropic-default",
    "check:no-anthropic-default": "scripts/check-no-anthropic-default.sh",
    "test": "tsx --test src/lib/*.test.ts src/lib/**/*.test.ts src/agents/*.test.ts",
    "eval:triage": "tsx evals/runner/run-triage.ts",
    "eval:judge": "tsx evals/judge/judge-triage.ts",
    "intake-api": "tsx src/bin/intake-api.ts",
    "controller": "tsx src/bin/controller.ts",
    "worker": "tsx src/bin/worker.ts",
    "pr-poller": "tsx src/bin/github-pr-poller.ts",
    "bot": "tsx src/bin/bot.ts",
    "gate:check": "tsx src/bin/gate-check.ts",
    "runs": "tsx src/bin/runs.ts",
    "run-to-pr": "tsx src/bin/run-to-pr.ts",
    "llm-run": "tsx src/bin/llm-run.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@aws-sdk/client-s3": "^3.1058.0",
    "@aws-sdk/lib-storage": "^3.1058.0",
    "@google-cloud/storage": "^7.19.0",
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.13",
    "@kubernetes/client-node": "^1.4.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "openai": "^6.38.0",
    "prom-client": "^15.1.3",
    "redis": "^5.8.2",
    "yaml": "^2.8.3"
  }
}
